<UserControl x:Class="Quizzer.Views.BuzzerViews.BuzzerControlsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Quizzer.Views.BuzzerViews"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel Grid.Column="2" Orientation="Vertical">
            <StackPanel Orientation="Horizontal">
                <Label Content="{Binding BuzzerState}"></Label>
            </StackPanel>
            <StackPanel x:Name="DefaultView" Orientation="Horizontal">
                <Button Content="Reset Round" Command="{Binding ResetRoundCommand}" />
                <Button Content="Test" Command="{Binding ResetRoundCommand}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>