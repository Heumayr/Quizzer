<base:WindowBase x:Class="Quizzer.Views.EditQuestionsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Quizzer.Views"
        xmlns:base="clr-namespace:Quizzer.Base"
        xmlns:val="clr-namespace:Quizzer.Validators"
        mc:Ignorable="d"
        Title="EditQuestionsView" Height="450" Width="800">
    <base:WindowBase.DataContext>
        <local:EditQuestionViewModel />
    </base:WindowBase.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Margin="5">
            <Button Content="Save" Width="120" Height="20" Margin="0,0,0,10" Command="{Binding SaveCommand}" />
            <Button Content="Save and Close" Width="120" Height="20" Margin="0,0,0,10" Command="{Binding SaveAndCloseCommand}" />
        </StackPanel>

        <StackPanel Grid.Column="1">
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Designation:" VerticalAlignment="Center" />
                <TextBox Text="{Binding Path=Question.Designation, UpdateSourceTrigger=PropertyChanged}" MinWidth="200" Margin="5,0,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120"  Content="Category:" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding Path=SelectedCategory, UpdateSourceTrigger=PropertyChanged}"
                          DisplayMemberPath="Designation"
                          MinWidth="200" Margin="5,0,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120"  Content="Difficulty:" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding Difficulties}"
                      SelectedItem="{Binding Question.Difficulty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      MinWidth="200" Margin="5,0,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Points:" VerticalAlignment="Center" />
                <TextBox MinWidth="200" Margin="5,0,0,0">
                    <TextBox.Text>
                        <Binding Path="Question.Points"
                             UpdateSourceTrigger="PropertyChanged"
                             ValidatesOnDataErrors="True"
                             ValidatesOnExceptions="True"
                             NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <val:PositiveIntValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Minus-Points:" VerticalAlignment="Center" />
                <TextBox MinWidth="200" Margin="5,0,0,0">
                    <TextBox.Text>
                        <Binding Path="Question.MinusPoints"
                                  UpdateSourceTrigger="PropertyChanged"
                                  ValidatesOnDataErrors="True"
                                  ValidatesOnExceptions="True"
                                  NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <val:PositiveIntValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Notes:" VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                     Text="{Binding Question.Notes, UpdateSourceTrigger=PropertyChanged}"
                     Margin="5,0,0,0"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     MinWidth="500"
                     MinHeight="60"
                     MaxHeight="200"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Top" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5,10,0,0">
                <Button Content="Add Step" Width="120" Height="20" Margin="0,0,0,0" Command="{Binding AddStepCommnad}" />
            </StackPanel>
            <DataGrid ItemsSource="{Binding Question.Steps}" AutoGenerateColumns="True" Margin="5" CanUserAddRows="False" IsReadOnly="True"
                      base:DataGridSelectedItemsBehavior.SelectedItems="{Binding SelectedSteps}"
                      base:DataGridRowDoubleClickBehavior.DoubleClickCommand="{Binding OpenStepCommand}">
                <!--<DataGrid.Columns>
                    <DataGridTextColumn Header="StepText" Binding="{Binding StepText}" Width="2*" />
                </DataGrid.Columns>-->
            </DataGrid>
        </StackPanel>
    </Grid>
</base:WindowBase>