<local:UserControlStepViewBase x:Class="Quizzer.Views.GameViews.QuestionViews.Typed.MultipleChoiceStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Quizzer.Views.GameViews.QuestionViews.Typed"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Label FontSize="30" Content="{Binding Step.StepText}"></Label>

        <Viewbox Grid.Row="1" Grid.Column="1">
            <local:ResourceViewerControl
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch"
                 DataContext="{Binding Step}"
                 RootFolder="{Binding DataContext.ResourceRootFolder, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 IsMasterView="{Binding DataContext.IsMasterView, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 AudioPlaceholderFile="{Binding DataContext.AudioPlaceholderFile, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </Viewbox>
    </Grid>
</local:UserControlStepViewBase>