<local:UserControlStepViewBase x:Class="Quizzer.Views.GameViews.QuestionViews.Typed.MultipleChoiceStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Quizzer.Views.GameViews.QuestionViews.Typed"
             xmlns:qv="clr-namespace:Quizzer.DataModels.Enumerations;assembly=Quizzer.DataModels"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <UserControl.Resources>

        <Style x:Key="StretchItemContainerStyle" TargetType="ContentPresenter">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <DataTemplate x:Key="StepItemTemplate">
            <Border Margin="8"
                    Padding="24,16"
                    CornerRadius="3"
                    Background="{Binding GridBackground}"
                    Visibility="{Binding SlotVisibility}"
                    Opacity="{Binding SlotOpacity}"
                    IsHitTestVisible="{Binding SlotHitTestVisible}"
                    ClipToBounds="True"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Key -->
                    <Grid Grid.Column="0">
                        <Viewbox Width="72"
                                 Height="72"
                                 Stretch="Uniform"
                                 StretchDirection="DownOnly"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <TextBlock Text="{Binding QuestionViewKey}"
                                       FontSize="56"
                                       FontWeight="Bold"
                                       Foreground="Wheat"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Viewbox>
                    </Grid>

                    <!-- Content -->
                    <Grid Grid.Column="1" Margin="16,0,0,0">

                        <!-- text + media -->
                        <Viewbox Visibility="{Binding TextAndMediaVisibility}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                   Text="{Binding DisplayText}"
                                   FontSize="38"
                                   FontWeight="SemiBold"
                                   Foreground="WhiteSmoke"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />

                                <Border Grid.Column="2"
                                    Width="220"
                                    Height="220"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                    <local:ResourceViewerControl
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    DataContext="{Binding Step}"
                                    RootFolder="{Binding DataContext.ResourceRootFolder, RelativeSource={RelativeSource AncestorType={x:Type local:UserControlStepViewBase}}}"
                                    IsMasterView="{Binding DataContext.IsMasterView, RelativeSource={RelativeSource AncestorType={x:Type local:UserControlStepViewBase}}}"
                                    AudioPlaceholderFile="{Binding DataContext.AudioPlaceholderFile, RelativeSource={RelativeSource AncestorType={x:Type local:UserControlStepViewBase}}}" />
                                </Border>
                            </Grid>
                        </Viewbox>

                        <!-- text only -->
                        <Viewbox Visibility="{Binding TextOnlyVisibility}">
                            <Grid>
                                <TextBlock Text="{Binding DisplayText}"
                                   Margin="10, 10, 20, 10"
                                   FontSize="44"
                                   FontWeight="SemiBold"
                                   Foreground="WhiteSmoke"
                                   TextWrapping="Wrap"
                                   TextAlignment="Left"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   MaxWidth="900" />
                            </Grid>
                        </Viewbox>

                        <!-- media only -->
                        <Viewbox Visibility="{Binding MediaOnlyVisibility}">
                            <Grid>
                                <Border Margin="0,15,0,0"
                                    Width="700"
                                    Height="300"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                    <local:ResourceViewerControl
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    DataContext="{Binding Step}"
                                    RootFolder="{Binding DataContext.ResourceRootFolder, RelativeSource={RelativeSource AncestorType={x:Type local:UserControlStepViewBase}}}"
                                    IsMasterView="{Binding DataContext.IsMasterView, RelativeSource={RelativeSource AncestorType={x:Type local:UserControlStepViewBase}}}"
                                    AudioPlaceholderFile="{Binding DataContext.AudioPlaceholderFile, RelativeSource={RelativeSource AncestorType={x:Type local:UserControlStepViewBase}}}" />
                                </Border>
                            </Grid>
                        </Viewbox>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="GridOnlyLayoutTemplate">
            <ItemsControl ItemsSource="{Binding DisplaySteps}"
                          ItemTemplate="{StaticResource StepItemTemplate}"
                          ItemContainerStyle="{StaticResource StretchItemContainerStyle}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="{Binding DisplayGridRows}"
                                     Columns="{Binding DisplayGridColumns}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </DataTemplate>

        <DataTemplate x:Key="NotSupportedTemplate">
            <Grid ClipToBounds="True">
                <TextBlock Text="Not Supported"
                           Foreground="WhiteSmoke"
                           FontSize="32"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center" />
            </Grid>
        </DataTemplate>

        <!-- only ONE active answer layout -->
        <DataTemplate x:Key="LayoutTemplate">
            <Grid ClipToBounds="True">
                <ContentControl Content="{Binding}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Setter Property="ContentTemplate"
                                    Value="{StaticResource NotSupportedTemplate}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DisplayLayoutMode}"
                                             Value="{x:Static qv:StepDisplayLayoutMode.Grid}">
                                    <Setter Property="ContentTemplate"
                                            Value="{StaticResource GridOnlyLayoutTemplate}" />
                                </DataTrigger>

                                <DataTrigger Binding="{Binding DisplayLayoutMode}"
                                             Value="{x:Static qv:StepDisplayLayoutMode.Vertical}">
                                    <Setter Property="ContentTemplate"
                                            Value="{StaticResource NotSupportedTemplate}" />
                                </DataTrigger>

                                <DataTrigger Binding="{Binding DisplayLayoutMode}"
                                             Value="{x:Static qv:StepDisplayLayoutMode.Horizontal}">
                                    <Setter Property="ContentTemplate"
                                            Value="{StaticResource NotSupportedTemplate}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Grid>
        </DataTemplate>

        <!-- player host -->
        <DataTemplate x:Key="PlayerHostTemplate">
            <Grid ClipToBounds="True">
                <ContentControl Content="{Binding}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                ContentTemplate="{StaticResource LayoutTemplate}" />
            </Grid>
        </DataTemplate>

        <!-- master host -->
        <DataTemplate x:Key="MasterHostTemplate">
            <Viewbox Stretch="Uniform"
                     StretchDirection="DownOnly">
                <Border Width="1600"
                        Height="900"
                        ClipToBounds="True">
                    <ContentControl Content="{Binding}"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
                                    ContentTemplate="{StaticResource LayoutTemplate}" />
                </Border>
            </Viewbox>
        </DataTemplate>
    </UserControl.Resources>

    <Grid ClipToBounds="True"
          SnapsToDevicePixels="True"
          UseLayoutRounding="True">

        <ContentControl Content="{Binding}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="ContentTemplate"
                            Value="{StaticResource PlayerHostTemplate}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMasterView}" Value="True">
                            <Setter Property="ContentTemplate"
                                    Value="{StaticResource MasterHostTemplate}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>
    </Grid>
</local:UserControlStepViewBase>