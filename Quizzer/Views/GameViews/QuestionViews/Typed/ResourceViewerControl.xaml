<local:UserControlStepViewBase x:Class="Quizzer.Views.GameViews.QuestionViews.Typed.ResourceViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Quizzer.Views.GameViews.QuestionViews.Typed"
             mc:Ignorable="d">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="MediaDesignation"
                   Text="{Binding ResourceFileName}"
                   FontWeight="Bold"
                   Margin="0,0,0,8"
                   Visibility="Collapsed" />

        <!-- IMAGE -->
        <Border x:Name="ImageContainer"
                Grid.Row="1"
                BorderBrush="black"
                BorderThickness="1"
                Padding="4"
                Background="Black"
                Visibility="Collapsed">
            <Image x:Name="ImgPreview"
                   Stretch="Uniform"
                   Visibility="Collapsed" />
        </Border>

        <!-- MEDIA -->
        <Grid Grid.Row="1"
              x:Name="MediaContainer"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="MediaPlayerBorder"
                    Grid.Row="0"
                    BorderBrush="Black"
                    BorderThickness="3"
                    CornerRadius="3"
                    Padding="4"
                    Background="Black"
                    Visibility="Collapsed">
                <Grid>
                    <Image x:Name="AudioPlaceholder"
                          Stretch="Uniform"
                          Visibility="Collapsed" />

                    <MediaElement x:Name="MediaPlayer"
                         LoadedBehavior="Manual"
                         UnloadedBehavior="Manual"
                         Stretch="Uniform" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="1"
                        x:Name="MediaControls"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,0"
                        Visibility="Collapsed">
                <Button Content="Start"
                        Width="90"
                        Margin="4"
                        Click="Start_Click" />
                <Button Content="Stop"
                        Width="90"
                        Margin="4"
                        Click="Stop_Click" />
            </StackPanel>
        </Grid>

        <!-- DOCUMENT -->
        <Border Grid.Row="1"
                x:Name="DocumentContainer"
                Visibility="Collapsed"
                BorderBrush="black"
                BorderThickness="1"
                Padding="12"
                Background="Black">
            <TextBlock Text="Dokument kann hier nicht direkt angezeigt werden."
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</local:UserControlStepViewBase>