<base:WindowBase x:Class="Quizzer.Views.GameViews.QuestionViews.Typed.Media.MediaPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Quizzer.Views.GameViews.QuestionViews.Typed.Media"
        xmlns:base="clr-namespace:Quizzer.Base"
        mc:Ignorable="d"
        Title="MediaPreviewWindow" Height="450" Width="800">
    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="Black">
            <Image x:Name="ImageViewer"
                   Stretch="Uniform"
                   Visibility="Collapsed" />

            <MediaElement x:Name="VideoViewer"
                          LoadedBehavior="Manual"
                          UnloadedBehavior="Manual"
                          Stretch="Uniform"
                          Visibility="Collapsed" />
        </Grid>

        <Border x:Name="ControlBar"
                Grid.Row="1"
                Background="#CC111111"
                Padding="12"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button Content="Start all"
                        Width="120"
                        Margin="6"
                        Click="StartAll_Click" />

                <Button Content="Stop all"
                        Width="120"
                        Margin="6"
                        Click="StopAll_Click" />

                <Button Content="Close all"
                        Width="120"
                        Margin="6"
                        Click="CloseAll_Click" />
            </StackPanel>
        </Border>
    </Grid>
</base:WindowBase>