<local:UserControlStepViewBase x:Class="Quizzer.Views.GameViews.QuestionViews.Typed.DefaultStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Quizzer.Views.GameViews.QuestionViews.Typed"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Result -->
        <StackPanel Grid.Row="0" 
                    Orientation="Horizontal"
                    HorizontalAlignment="left"
                    Visibility="{Binding MasterViewVisibility}"
                    Margin="4">
            <Label Content="Result:" />
            <CheckBox VerticalContentAlignment="Center"
                      IsEnabled="False"
                      IsChecked="{Binding Step.IsResult}" />
        </StackPanel>

        <!-- Finish -->
        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal"
                    HorizontalAlignment="left"
                    Visibility="{Binding MasterViewVisibility}"
                    Margin="4">
            <Label Content="Finish:" />
            <CheckBox VerticalContentAlignment="Center"
                      IsEnabled="False"
                      IsChecked="{Binding Step.IsFinish}" />
        </StackPanel>

        <!-- Main content area -->
        <Grid Grid.Row="2" ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="{Binding ResourceRowHeight}"></RowDefinition>
                <RowDefinition Height="{Binding StepTextRowHeight}"></RowDefinition>
            </Grid.RowDefinitions>

            <!-- Step text -->
            <Border Grid.Column="0" Grid.Row="1" Background="{Binding TextBackgroundBrush}" Visibility="{Binding HasStepTextVisibility}">
                <Grid 
                   Margin="4"
                   ClipToBounds="True">
                    <Viewbox Stretch="Uniform"
                          StretchDirection="Both"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="10">
                        <TextBlock Text="{Binding Step.StepText}"
                    Foreground="{Binding TextForgroundBrush}"
                    TextWrapping="Wrap"
                    TextAlignment="Center" />
                    </Viewbox>
                </Grid>
            </Border>

            <!-- Resource -->
            <Grid Grid.Column="0" Grid.Row="0"
                  Margin="4"
                  ClipToBounds="True"
                  Visibility="{Binding HasResourceVisibility}">
                <local:ResourceViewerControl
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    DataContext="{Binding Step}"
                    RootFolder="{Binding DataContext.ResourceRootFolder, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    IsMasterView="{Binding DataContext.IsMasterView, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    AudioPlaceholderFile="{Binding DataContext.AudioPlaceholderFile, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </Grid>
        </Grid>
    </Grid>
</local:UserControlStepViewBase>