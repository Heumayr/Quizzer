<base:WindowBase x:Class="Quizzer.Views.GameViews.GamePlayerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Quizzer.Views.GameViews"
        xmlns:base="clr-namespace:Quizzer.Base"
        xmlns:helper="clr-namespace:Quizzer.Views.HelperViewModels"
        xmlns:typed="clr-namespace:Quizzer.Views.GameViews.QuestionViews.Typed"
        xmlns:questions="clr-namespace:Quizzer.Views.GameViews.QuestionViews"
        xmlns:sub="clr-namespace:Quizzer.Views.GameViews.Sub"
        mc:Ignorable="d"
        Title="GamePlayerView" Height="450" Width="800">
    <base:WindowBase.DataContext>
        <local:GamePlayerViewModel></local:GamePlayerViewModel>
    </base:WindowBase.DataContext>
    <base:WindowBase.Resources>
        <ItemsPanelTemplate x:Key="MatrixPanel">
            <Grid
             base:MatrixGridBehavior.Rows="{Binding DataContext.Height, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
             base:MatrixGridBehavior.Columns="{Binding DataContext.Width, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
             base:MatrixGridBehavior.CellWidth="{Binding DataContext.CellWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
             base:MatrixGridBehavior.CellHeight="{Binding DataContext.CellHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
        </ItemsPanelTemplate>

        <questions:QuestionStepTemplateSelector x:Key="QuestionStepTemplateSelector" />

        <DataTemplate x:Key="DefaultStepTemplate">
            <typed:DefaultStepView IsMasterView="False" />
        </DataTemplate>

        <DataTemplate x:Key="MultipleChoiceStepTemplate">
            <typed:MultipleChoiceStepView IsMasterView="False" />
        </DataTemplate>

        <DataTemplate x:Key="PropertiesStepTemplate">
            <typed:PropertiesStepView IsMasterView="False" />
        </DataTemplate>

        <DataTemplate x:Key="AppreciateStepTemplate">
            <typed:AppreciateStepView IsMasterView="False" />
        </DataTemplate>

        <base:BottomStatsRowHeightConverter x:Key="BottomStatsRowHeightConverter" />
        <base:MainContentRowHeightConverter x:Key="MainContentRowHeightConverter" />
    </base:WindowBase.Resources>
    <Grid Background="{Binding PlayGroundBackGroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="{Binding ShowBottomStats, Converter={StaticResource MainContentRowHeightConverter}}" />
            <RowDefinition Height="{Binding ShowBottomStats, Converter={StaticResource BottomStatsRowHeightConverter}}" />
        </Grid.RowDefinitions>

        <!-- MAIN AREA -->
        <Grid Grid.Row="0" Visibility="{Binding ShowMainContent}">
            <Viewbox Visibility="{Binding ShowGameGridView}" Margin="5"
                 Stretch="Uniform"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Column headers -->
                    <ItemsControl ItemsSource="{Binding ColumnHeaderVMs}" ItemsPanel="{StaticResource MatrixPanel}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Grid.Row" Value="{Binding GridRow}" />
                                <Setter Property="Grid.Column" Value="{Binding GridColumn}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="2"
                                    Background="{Binding DataContext.HeaderColumnBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    SnapsToDevicePixels="True"
                                    Margin="3">
                                    <TextBox IsReadOnly="{Binding LockHeader}"
                                         Text="{Binding TextLong, Mode=OneWay}"
                                         Background="Transparent"
                                         Foreground="WhiteSmoke"
                                         BorderThickness="0"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         TextAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         Padding="4"
                                         HorizontalScrollBarVisibility="Disabled"
                                         VerticalScrollBarVisibility="Disabled"
                                         base:AutoFitTextBox.IsEnabled="True"
                                         base:AutoFitTextBox.MinFontSize="6"
                                         base:AutoFitTextBox.MaxFontSize="22" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Row headers -->
                    <ItemsControl ItemsSource="{Binding RowHeaderVMs}" ItemsPanel="{StaticResource MatrixPanel}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Grid.Row" Value="{Binding GridRow}" />
                                <Setter Property="Grid.Column" Value="{Binding GridColumn}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="2"
                                    Background="{Binding DataContext.HeaderRowBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    SnapsToDevicePixels="True"
                                    Margin="3">
                                    <TextBox IsReadOnly="{Binding LockHeader}"
                                         Text="{Binding TextLong, Mode=OneWay}"
                                         Background="Transparent"
                                         Foreground="WhiteSmoke"
                                         BorderThickness="0"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         TextAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         Padding="4"
                                         HorizontalScrollBarVisibility="Disabled"
                                         VerticalScrollBarVisibility="Disabled"
                                         base:AutoFitTextBox.IsEnabled="True"
                                         base:AutoFitTextBox.MinFontSize="6"
                                         base:AutoFitTextBox.MaxFontSize="22" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Cells -->
                    <ItemsControl ItemsSource="{Binding CellVMs}" ItemsPanel="{StaticResource MatrixPanel}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Grid.Row" Value="{Binding GridRow}" />
                                <Setter Property="Grid.Column" Value="{Binding GridColumn}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <helper:UcCellViewPlay
                                Command="{Binding DataContext.CellClickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                Margin="2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Viewbox>

            <Grid Visibility="{Binding ShowQuestionView}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="Black" MaxHeight="100">
                    <Viewbox Margin="5" Stretch="Uniform" Visibility="{Binding ShowQuestionText}">
                        <TextBlock Text="{Binding QuestionText}"
                               Foreground="WhiteSmoke"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                    </Viewbox>
                </Grid>

                <Grid Grid.Row="1">
                    <ContentControl Content="{Binding QuestionStepViewContext}"
                                ContentTemplateSelector="{StaticResource QuestionStepTemplateSelector}" />
                </Grid>
            </Grid>
        </Grid>

        <!-- BOTTOM STATS -->
        <Border Grid.Row="1"
            Visibility="{Binding ShowBottomStats}"
            Background="Transparent"
            Margin="5">
            <Viewbox Stretch="Uniform">
                <sub:UcStatsView DataContext="{Binding StatsContext}" />
            </Viewbox>
        </Border>

        <!-- FULLSCREEN STATS -->
        <Grid Grid.Row="0"
          Grid.RowSpan="2"
          Visibility="{Binding ShowFullscreenStats}">
            <Viewbox Stretch="Uniform">
                <sub:UcStatsView DataContext="{Binding StatsContext}" />
            </Viewbox>
        </Grid>
    </Grid>
</base:WindowBase>