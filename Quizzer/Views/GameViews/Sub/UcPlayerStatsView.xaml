<UserControl x:Class="Quizzer.Views.GameViews.Sub.UcPlayerStatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Quizzer.Views.GameViews.Sub"
             mc:Ignorable="d"
             d:DesignHeight="340" d:DesignWidth="220"
             Width="220"
             Height="340">

    <Border BorderThickness="2"
            BorderBrush="Transparent"
            CornerRadius="2"
            Background="{Binding BackgroundBrush}"
            Padding="12">

        <Grid Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="44" />
                <RowDefinition Height="10" />
                <RowDefinition Height="140" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- placement -->
            <TextBlock Text="{Binding PlacementText}"
                       Foreground="#C8A96B"
                       FontWeight="Bold"
                       FontSize="24"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Panel.ZIndex="100"
                       Margin="0,0,4,0" />

            <!-- designation -->
            <TextBlock Grid.Row="0"
                    Text="{Binding Player.Designation}"
                    FontSize="24"
                    Foreground="{Binding DesignationBrush}"
                    FontWeight="DemiBold"
                    TextAlignment="Center"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    TextWrapping="Wrap" />

            <!-- display name -->
            <TextBlock Grid.Row="1"
                       Text="{Binding Player.DisplayName}"
                       FontSize="28"
                       Foreground="Wheat"
                       FontWeight="ExtraBold"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />

            <!-- image -->
            <Border Grid.Row="3"
                    Width="130"
                    Height="130"
                    Margin="0,6,0,6"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderThickness="3"
                    CornerRadius="12"
                    BorderBrush="#333333">
                <Border.Background>
                    <ImageBrush ImageSource="{Binding PlayerImagePath}"
                                Stretch="UniformToFill" />
                </Border.Background>
            </Border>

            <!-- score -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,0,0,0">
                <TextBlock Foreground="AntiqueWhite"
                           FontWeight="ExtraBold"
                           FontSize="24"
                           Text="Score: " />
                <TextBlock Foreground="AntiqueWhite"
                           FontWeight="ExtraBold"
                           FontSize="24"
                           Text="{Binding ActualScore}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>