<UserControl x:Class="Quizzer.Views.GameViews.Sub.UcPlayerResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Quizzer.Views.GameViews.Sub"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <!--<UserControl.DataContext>
        <local:PlayerResultContext></local:PlayerResultContext>
    </UserControl.DataContext>-->
    <Grid MinHeight="50" MinWidth="50">
        <Label Content="{Binding Player.Designation}"></Label>
        <CheckBox IsEnabled="False" IsChecked="{Binding IsBuzzerWinner, Mode=OneWay}"></CheckBox>
    </Grid>
</UserControl>