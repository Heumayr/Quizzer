<base:WindowBase x:Class="Quizzer.Views.GameViews.GameMasterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Quizzer.Views.GameViews"
        xmlns:base="clr-namespace:Quizzer.Base"
        xmlns:helper="clr-namespace:Quizzer.Views.HelperViewModels"
        mc:Ignorable="d"
        Title="GameMasterView" Height="450" Width="800">
    <base:WindowBase.DataContext>
        <local:GameMasterViewModel />
    </base:WindowBase.DataContext>
    <base:WindowBase.Resources>
        <ItemsPanelTemplate x:Key="MatrixPanel">
            <Grid
                base:MatrixGridBehavior.Rows="{Binding DataContext.Height, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                base:MatrixGridBehavior.Columns="{Binding DataContext.Width, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                base:MatrixGridBehavior.CellWidth="{Binding DataContext.CellWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                base:MatrixGridBehavior.CellHeight="{Binding DataContext.CellHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
        </ItemsPanelTemplate>
    </base:WindowBase.Resources>
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="{Binding BackgroundImagePath}"
             Stretch="UniformToFill" />
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="0">
            <Button Content="Buzzer Server" Command="{Binding BuzzerServerCommand}" />
            <Button Content="Open Player View" Command="{Binding OpenGamePlayerViewCommand}" />
        </StackPanel>
        <Viewbox Visibility="{Binding ShowGameGridView}" Margin="5" Grid.Column="1" Grid.Row="0"
              Stretch="Uniform"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch">
            <Grid>
                <!-- Column headers -->
                <ItemsControl ItemsSource="{Binding ColumnHeaderVMs}" ItemsPanel="{StaticResource MatrixPanel}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Grid.Row" Value="{Binding GridRow}" />
                            <Setter Property="Grid.Column" Value="{Binding GridColumn}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10"
                                    Background="{Binding DataContext.HeaderColumnBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    SnapsToDevicePixels="True"
                                    Margin="3">
                                <TextBox IsReadOnly="{Binding LockHeader}"
                                         Text="{Binding TextLong, Mode=OneWay}"
                                         Background="Transparent"
                                         Foreground="WhiteSmoke"
                                         BorderThickness="0"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         TextAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         Padding="4"
                                         HorizontalScrollBarVisibility="Disabled"
                                         VerticalScrollBarVisibility="Disabled"
                                         base:AutoFitTextBox.IsEnabled="True"
                                         base:AutoFitTextBox.MinFontSize="6"
                                         base:AutoFitTextBox.MaxFontSize="22" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Row headers -->
                <ItemsControl ItemsSource="{Binding RowHeaderVMs}" ItemsPanel="{StaticResource MatrixPanel}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Grid.Row" Value="{Binding GridRow}" />
                            <Setter Property="Grid.Column" Value="{Binding GridColumn}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10"
                                    Background="{Binding DataContext.HeaderRowBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    SnapsToDevicePixels="True"
                                    Margin="3">
                                <TextBox IsReadOnly="{Binding LockHeader}"
                                        Text="{Binding TextLong, Mode=OneWay}"
                                        Background="Transparent"
                                        Foreground="WhiteSmoke"
                                        BorderThickness="0"
                                        AcceptsReturn="True"
                                        TextWrapping="Wrap"
                                        TextAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Padding="4"
                                        HorizontalScrollBarVisibility="Disabled"
                                        VerticalScrollBarVisibility="Disabled"
                                        base:AutoFitTextBox.IsEnabled="True"
                                        base:AutoFitTextBox.MinFontSize="6"
                                        base:AutoFitTextBox.MaxFontSize="22" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Cells -->
                <ItemsControl ItemsSource="{Binding CellVMs}" ItemsPanel="{StaticResource MatrixPanel}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Grid.Row" Value="{Binding GridRow}" />
                            <Setter Property="Grid.Column" Value="{Binding GridColumn}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <helper:UcCellViewPlay
                                Command="{Binding DataContext.CellClickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                Margin="2" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Viewbox>
    </Grid>
</base:WindowBase>