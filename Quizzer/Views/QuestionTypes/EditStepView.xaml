<base:WindowBase x:Class="Quizzer.Views.QuestionTypes.EditStepView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Quizzer.Views.QuestionTypes"
        xmlns:base="clr-namespace:Quizzer.Base"
        xmlns:val="clr-namespace:Quizzer.Validators"
        mc:Ignorable="d"
        Title="EditStepView" Height="450" Width="800">
    <base:WindowBase.DataContext>
        <local:EditStepViewModel />
    </base:WindowBase.DataContext>
    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Margin="5">
            <Button Content="Save" Command="{Binding SaveCommand}" />
            <Button Content="Save and Close" Command="{Binding SaveAndCloseCommand}" />
        </StackPanel>

        <StackPanel Grid.Column="1">
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Designation:" VerticalAlignment="Center" />
                <TextBox VerticalContentAlignment="Center" Text="{Binding Step.Designation}" MinWidth="200" Height="25" Margin="5,0,0,0"></TextBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Sequenz Number:" VerticalAlignment="Center" />
                <TextBox VerticalContentAlignment="Center" MinWidth="200" Margin="5,0,0,0">
                    <TextBox.Text>
                        <Binding Path="Step.SequenceNumber"
                                 UpdateSourceTrigger="PropertyChanged"
                                 ValidatesOnDataErrors="True"
                                 ValidatesOnExceptions="True"
                                 NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <val:PositiveIntValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Is Result:" VerticalAlignment="Center" />
                <CheckBox VerticalAlignment="Center" IsChecked="{Binding Path=Step.IsResult, UpdateSourceTrigger=PropertyChanged}" Margin="5,0,0,0" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Is Finish:" VerticalAlignment="Center" />
                <CheckBox VerticalAlignment="Center" IsChecked="{Binding Path=Step.IsFinish, UpdateSourceTrigger=PropertyChanged}" Margin="5,0,0,0" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Text:" VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                    Text="{Binding Step.StepText, UpdateSourceTrigger=PropertyChanged}"
                    Margin="5,0,0,0"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto"
                    MinWidth="500"
                    MinHeight="60"
                    MaxHeight="200"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Resource Filename:" VerticalAlignment="Center" />
                <TextBox IsEnabled="False" Height="25" VerticalContentAlignment="Center" Text="{Binding Path=Step.ResourceFileName, UpdateSourceTrigger=PropertyChanged}" MinWidth="200" Margin="5,0,0,0" Width="350" />
                <Button Content="Select" Command="{Binding SelectResourceCommnad}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120"  Content="Resource Typ:" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding ResourceTyps}"
                    SelectedItem="{Binding Step.ResourceTyp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    MinWidth="200" Margin="5,0,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5,10,0,0">
                <ComboBox MinWidth="200" Height="25" ItemsSource="{Binding CmbSource}" SelectedItem="{Binding CmbSelectedStep}"></ComboBox>
                <Button Content="Add Step" Command="{Binding AddStepCommnad}" />
                <Button Content="Remove Step" Command="{Binding RemoveStepCommnad}" Style="{StaticResource DangerButton}" />
            </StackPanel>
            <DataGrid ItemsSource="{Binding Froms}" AutoGenerateColumns="True" Margin="5" CanUserAddRows="False" IsReadOnly="True"
                    base:DataGridSelectedItemsBehavior.SelectedItems="{Binding SelectedStepXSteps}"
                    base:DataGridRowDoubleClickBehavior.DoubleClickCommand="{Binding OpenStepCommand}">
            </DataGrid>
        </StackPanel>
    </Grid>
</base:WindowBase>