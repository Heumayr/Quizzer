<base:WindowBase x:Class="Quizzer.Views.QuestionTypes.EditQuestionsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Quizzer.Views.QuestionTypes"
        xmlns:base="clr-namespace:Quizzer.Base"
        xmlns:val="clr-namespace:Quizzer.Validators"
        mc:Ignorable="d"
        Title="EditQuestionsView" Height="626" Width="855">
    <base:WindowBase.DataContext>
        <local:EditQuestionViewModel />
    </base:WindowBase.DataContext>
    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Margin="5">
            <Button Content="Save" Command="{Binding SaveCommand}" />
            <Button Content="Save and Close" Command="{Binding SaveAndCloseCommand}" />
        </StackPanel>

        <StackPanel Grid.Column="1">
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Designation:" VerticalAlignment="Center" />
                <TextBox VerticalContentAlignment="Center" Text="{Binding Path=Question.Designation, UpdateSourceTrigger=PropertyChanged}" MinWidth="200" Margin="5,0,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Designation short:" VerticalAlignment="Center" />
                <TextBox VerticalContentAlignment="Center" Text="{Binding Path=Question.DesignationShort, UpdateSourceTrigger=PropertyChanged}" MinWidth="200" Margin="5,0,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Question Text:" VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                      Text="{Binding Question.QuestionText, UpdateSourceTrigger=PropertyChanged}"
                      Margin="5,0,0,0"
                      AcceptsReturn="True"
                      TextWrapping="Wrap"
                      VerticalScrollBarVisibility="Auto"
                      MinWidth="500"
                      MinHeight="60"
                      MaxHeight="200"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Top" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120"  Content="Category:" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding Path=SelectedCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          DisplayMemberPath="Designation"
                          MinWidth="200" Margin="5,0,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120"  Content="Difficulty:" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding Difficulties}"
                      SelectedItem="{Binding Question.Difficulty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      MinWidth="200" Margin="5,0,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Points:" VerticalAlignment="Center" />
                <TextBox VerticalContentAlignment="Center" MinWidth="200" Margin="5,0,0,0">
                    <TextBox.Text>
                        <Binding Path="Question.Points"
                             UpdateSourceTrigger="PropertyChanged"
                             ValidatesOnDataErrors="True"
                             ValidatesOnExceptions="True"
                             NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <val:PositiveIntValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Minus-Points:" VerticalAlignment="Center" />
                <TextBox VerticalContentAlignment="Center" MinWidth="200" Margin="5,0,0,0">
                    <TextBox.Text>
                        <Binding Path="Question.MinusPoints"
                                  UpdateSourceTrigger="PropertyChanged"
                                  ValidatesOnDataErrors="True"
                                  ValidatesOnExceptions="True"
                                  NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <val:PositiveIntValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Notes:" VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                     Text="{Binding Question.Notes, UpdateSourceTrigger=PropertyChanged}"
                     Margin="5,0,0,0"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     MinWidth="500"
                     MinHeight="60"
                     MaxHeight="200"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Top" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Warn on result step:" VerticalAlignment="Center" />
                <CheckBox VerticalContentAlignment="Center" IsChecked="{Binding Path=Question.WarnOnResultStep}" MinWidth="200" Margin="5,0,0,0" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Warn on finish step:" VerticalAlignment="Center" />
                <CheckBox VerticalContentAlignment="Center" IsChecked="{Binding Path=Question.WarnOnFinishStep}" MinWidth="200" Margin="5,0,0,0" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Random Sequence:" VerticalAlignment="Center" />
                <CheckBox VerticalContentAlignment="Center" IsChecked="{Binding Path=Question.UseRandomSequenceOnNonFinishSteps}" MinWidth="200" Margin="5,0,0,0" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5,10,0,0">
                <Button Content="Add Step" Command="{Binding AddStepCommnad}" />
                <Button Content="Remove Step" Command="{Binding RemoveStepCommnad}" Style="{StaticResource DangerButton}" />
            </StackPanel>
            <DataGrid ItemsSource="{Binding StepsView}" AutoGenerateColumns="True" Margin="5" CanUserAddRows="False" IsReadOnly="True"
                      base:DataGridSelectedItemsBehavior.SelectedItems="{Binding SelectedSteps}"
                      base:DataGridRowDoubleClickBehavior.DoubleClickCommand="{Binding OpenStepCommand}">
                <!--<DataGrid.Columns>
                    <DataGridTextColumn Header="StepText" Binding="{Binding StepText}" Width="2*" />
                </DataGrid.Columns>-->
            </DataGrid>
        </StackPanel>
    </Grid>
</base:WindowBase>