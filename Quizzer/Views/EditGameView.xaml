<base:WindowBase x:Class="Quizzer.Views.EditGameView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Quizzer.Views"
        xmlns:base="clr-namespace:Quizzer.Base"
        xmlns:val="clr-namespace:Quizzer.Validators"
        xmlns:helper="clr-namespace:Quizzer.Views.HelperViewModels"
        mc:Ignorable="d"
        Title="EditGameView" Height="450" Width="800">
    <base:WindowBase.DataContext>
        <local:EditGameViewModel />
    </base:WindowBase.DataContext>
    <base:WindowBase.Resources>
        <ItemsPanelTemplate x:Key="MatrixPanel">
            <Grid
                base:MatrixGridBehavior.Rows="{Binding DataContext.Height, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                base:MatrixGridBehavior.Columns="{Binding DataContext.Width, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                base:MatrixGridBehavior.CellWidth="{Binding DataContext.CellWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                base:MatrixGridBehavior.CellHeight="{Binding DataContext.CellHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
        </ItemsPanelTemplate>
    </base:WindowBase.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="5">
            <Button Content="Save" Command="{Binding SaveCommand}" />
            <Button Content="Save and Close" Command="{Binding SaveAndCloseCommand}" />
            <Button Content="Reset Game Build" Command="{Binding ResetGameBuildCommand}" Style="{StaticResource DangerButton}" />
            <Button Content="Enable Building" Command="{Binding SetToBuildingModeCommand}" />
        </StackPanel>

        <StackPanel IsEnabled="{Binding IsBuilding}" Grid.Column="1">
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Reset Game on Start:" VerticalAlignment="Center" />
                <CheckBox VerticalContentAlignment="Center" IsChecked="{Binding Restart}" MinWidth="200" Margin="5,0,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Designation:" VerticalAlignment="Center" />
                <TextBox VerticalContentAlignment="Center" Text="{Binding Path=Designation}" MinWidth="200" Margin="5,0,0,0" />
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal" Margin="5">
                    <ComboBox ItemsSource="{Binding AvailablePlayersView}" DisplayMemberPath="CalculatedDisplayName" SelectedItem="{Binding CmbSelectedPlayer}" Width="200" Margin="0,8,10,8" />
                    <Button Content="Add Player" Command="{Binding AddPlayerCommand}" />
                    <Button Content="Remove Player" Command="{Binding RemovePlayerCommand}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <Label MinWidth="120" Content="Players:" VerticalAlignment="Center" />
                    <ListView Margin="5,0,0,0" MinHeight="20" MinWidth="200" MaxWidth="250" ItemsSource="{Binding GameAddedPlayersView}" SelectedItem="{Binding SelectedPlayer}" />
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal" Margin="5">
                    <Label MinWidth="120" Content="Test Phase: "></Label>
                    <TextBox VerticalContentAlignment="Center" MinWidth="50" Margin="5,8,5,8">
                        <TextBox.Text>
                            <Binding Path="TestPhase" UpdateSourceTrigger="PropertyChanged" ValidatesOnDataErrors="True" ValidatesOnExceptions="True" NotifyOnValidationError="True">
                                <Binding.ValidationRules>
                                    <val:PositiveIntValidationRule />
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <Button Content="Refresh Grid" Command="{Binding RefreshGridCommand}" />
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Diff. x / +:" VerticalAlignment="Center" />
                <TextBox VerticalContentAlignment="Center" MinWidth="50" Margin="5,0,0,0">
                    <TextBox.Text>
                        <Binding Path="DifficultyMultiplier" UpdateSourceTrigger="LostFocus" ValidatesOnDataErrors="True" ValidatesOnExceptions="True" NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <val:PositiveDoubleValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
                <TextBox VerticalContentAlignment="Center" MinWidth="50" Margin="5,0,0,0">
                    <TextBox.Text>
                        <Binding Path="DifficultyAddition" UpdateSourceTrigger="PropertyChanged" ValidatesOnDataErrors="True" ValidatesOnExceptions="True" NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <val:PositiveIntValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
                <Label Margin="70,0,0,0" MinWidth="120" Content="Minus-Diff. x / +:" VerticalAlignment="Center" />
                <TextBox VerticalContentAlignment="Center" MinWidth="50" Margin="5,0,0,0">
                    <TextBox.Text>
                        <Binding Path="DifficultyMinusMultiplier" UpdateSourceTrigger="LostFocus" ValidatesOnDataErrors="True" ValidatesOnExceptions="True" NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <val:PositiveDoubleValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
                <TextBox VerticalContentAlignment="Center" MinWidth="50" Margin="5,0,0,0">
                    <TextBox.Text>
                        <Binding Path="DifficultyMinusAddition" UpdateSourceTrigger="PropertyChanged" ValidatesOnDataErrors="True" ValidatesOnExceptions="True" NotifyOnValidationError="True">
                            <!--<Binding.ValidationRules>
                                <val:PositiveIntValidationRule />
                            </Binding.ValidationRules>-->
                        </Binding>
                    </TextBox.Text>
                </TextBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Phase. x / +:" VerticalAlignment="Center" />
                <TextBox VerticalContentAlignment="Center" MinWidth="50" Margin="5,0,0,0">
                    <TextBox.Text>
                        <Binding Path="PhaseMultiplier" UpdateSourceTrigger="LostFocus" ValidatesOnDataErrors="True" ValidatesOnExceptions="True" NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <val:PositiveDoubleValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
                <TextBox VerticalContentAlignment="Center" MinWidth="50" Margin="5,0,0,0">
                    <TextBox.Text>
                        <Binding Path="PhaseAddition" UpdateSourceTrigger="PropertyChanged" ValidatesOnDataErrors="True" ValidatesOnExceptions="True" NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <val:PositiveIntValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="H/W:" VerticalAlignment="Center" />
                <TextBox VerticalContentAlignment="Center" MinWidth="50" Margin="5,0,0,0">
                    <TextBox.Text>
                        <Binding Path="Height" UpdateSourceTrigger="LostFocus" ValidatesOnDataErrors="True" ValidatesOnExceptions="True" NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <val:PositiveIntValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
                <TextBox VerticalContentAlignment="Center" MinWidth="50" Margin="5,0,0,0">
                    <TextBox.Text>
                        <Binding Path="Width" UpdateSourceTrigger="LostFocus" ValidatesOnDataErrors="True" ValidatesOnExceptions="True" NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <val:PositiveIntValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
                <!--<TextBox VerticalContentAlignment="Center" MinWidth="50" Margin="5,0,0,0">
                    <TextBox.Text>
                        <Binding Path="Game.Depth" UpdateSourceTrigger="PropertyChanged" ValidatesOnDataErrors="True" ValidatesOnExceptions="True" NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <val:PositiveIntValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>-->
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label MinWidth="120" Content="Box size H/W:" VerticalAlignment="Center" />
                <TextBox VerticalContentAlignment="Center" MinWidth="50" Margin="5,0,0,0">
                    <TextBox.Text>
                        <Binding Path="CellHeight" UpdateSourceTrigger="PropertyChanged" ValidatesOnDataErrors="True" ValidatesOnExceptions="True" NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <val:PositiveIntValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
                <TextBox VerticalContentAlignment="Center" MinWidth="50" Margin="5,0,0,0">
                    <TextBox.Text>
                        <Binding Path="CellWidth" UpdateSourceTrigger="PropertyChanged" ValidatesOnDataErrors="True" ValidatesOnExceptions="True" NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <val:PositiveIntValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
            </StackPanel>
        </StackPanel>
        <!--Gamegrid-->
        <ScrollViewer Margin="5" Grid.Column="2"
              HorizontalScrollBarVisibility="Auto"
              VerticalScrollBarVisibility="Auto"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Grid IsEnabled="{Binding IsBuilding}">
                <!-- Column headers -->
                <ItemsControl ItemsSource="{Binding ColumnHeaderVMs}" ItemsPanel="{StaticResource MatrixPanel}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Grid.Row" Value="{Binding GridRow}" />
                            <Setter Property="Grid.Column" Value="{Binding GridColumn}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10"
                            Background="DarkBlue"
                            SnapsToDevicePixels="True"
                            Margin="3">
                                <TextBox IsReadOnly="{Binding LockHeader}"
                               Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                               Background="Transparent"
                               Foreground="WhiteSmoke"
                               BorderThickness="0"
                               AcceptsReturn="True"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               VerticalContentAlignment="Center"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"
                               Padding="4"
                               HorizontalScrollBarVisibility="Disabled"
                               VerticalScrollBarVisibility="Disabled"
                               base:AutoFitTextBox.IsEnabled="True"
                               base:AutoFitTextBox.MinFontSize="6"
                               base:AutoFitTextBox.MaxFontSize="22" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Row headers -->
                <ItemsControl ItemsSource="{Binding RowHeaderVMs}" ItemsPanel="{StaticResource MatrixPanel}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Grid.Row" Value="{Binding GridRow}" />
                            <Setter Property="Grid.Column" Value="{Binding GridColumn}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10"
                         Background="DarkBlue"
                         SnapsToDevicePixels="True"
                         Margin="3">
                                <TextBox IsReadOnly="{Binding LockHeader}" Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                              Background="Transparent"
                              Foreground="WhiteSmoke"
                              BorderThickness="0"
                              AcceptsReturn="True"
                              TextWrapping="Wrap"
                              TextAlignment="Center"
                              VerticalContentAlignment="Center"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Padding="4"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Disabled"
                              base:AutoFitTextBox.IsEnabled="True"
                              base:AutoFitTextBox.MinFontSize="6"
                              base:AutoFitTextBox.MaxFontSize="22" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Cells -->
                <ItemsControl ItemsSource="{Binding CellVMs}" ItemsPanel="{StaticResource MatrixPanel}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Grid.Row" Value="{Binding GridRow}" />
                            <Setter Property="Grid.Column" Value="{Binding GridColumn}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <helper:UcCellView
                        Command="{Binding DataContext.CellClickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding}"
                        Margin="2" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</base:WindowBase>