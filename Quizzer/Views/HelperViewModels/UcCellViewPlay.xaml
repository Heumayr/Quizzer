<UserControl x:Class="Quizzer.Views.HelperViewModels.UcCellViewPlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:enums="clr-namespace:Quizzer.DataModels.Enumerations;assembly=Quizzer.DataModels"
             xmlns:base="clr-namespace:Quizzer.Base"
             x:Name="root">
    <UserControl.Resources>
        <Style x:Key="CellBorderStyle" TargetType="Border">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Background" Value="{Binding IsDoneBrush}" />
            <Setter Property="BorderBrush" Value="Black" />

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="DarkGreen" />
                    <Setter Property="BorderBrush" Value="Black" />
                    <Setter Property="BorderThickness" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Border Style="{StaticResource CellBorderStyle}">
        <Border.InputBindings>
            <MouseBinding MouseAction="LeftClick"
                       Command="{Binding ElementName=root, Path=Command}"
                       CommandParameter="{Binding ElementName=root, Path=CommandParameter}" />
        </Border.InputBindings>

        <Border Margin="2" Padding="6" BorderThickness="0" Background="Transparent">
            <Grid>
                <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <StackPanel.Resources>
                        <Style TargetType="Label">
                            <Setter Property="Padding" Value="3" />
                            <Setter Property="Margin" Value="0" />
                            <!-- center text inside each label -->
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                        </Style>
                    </StackPanel.Resources>

                    <Label FontSize="18" Foreground="{Binding IsDoneTextBrush}" Content="{Binding DisplayCoordsFull}" />
                    <Label FontSize="12" Foreground="{Binding IsDoneTextBrush}" Content="{Binding PointsDisplay}"
                           base:AutoFitLabel.IsEnabled="True"
                           base:AutoFitLabel.MinFontSize="6"
                           base:AutoFitLabel.MaxFontSize="22"
                           base:AutoFitLabel.WrapText="False" />
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</UserControl>