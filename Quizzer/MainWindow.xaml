<base:WindowBase x:Class="Quizzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Quizzer"
        xmlns:vm="clr-namespace:Quizzer.Views"
        xmlns:base="clr-namespace:Quizzer.Base"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <base:WindowBase.DataContext>
        <vm:MainViewModel />
    </base:WindowBase.DataContext>
    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Margin="5" Width="120">
            <Button Content="Categories" Command="{Binding CategoryCommand}" />
            <Button Content="Questions" Command="{Binding QuestionsCommand}" />
            <Button Content="Players" Command="{Binding PlayersCommand}" />
            <Button Content="Games" Command="{Binding GamesCommand}" />
        </StackPanel>
    </Grid>
</base:WindowBase>