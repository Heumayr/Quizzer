<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Theme tokens (colors) -->
    <Color x:Key="BtnBg">#151515</Color>
    <Color x:Key="BtnBgHover">#232323</Color>
    <Color x:Key="BtnBgPressed">#0C0C0C</Color>
    <Color x:Key="BtnBgDisabled">#434343</Color>

    <!-- Theme tokens (brushes) -->
    <SolidColorBrush x:Key="BtnBgBrush"         Color="{StaticResource BtnBg}" />
    <SolidColorBrush x:Key="BtnBgHoverBrush"    Color="{StaticResource BtnBgHover}" />
    <SolidColorBrush x:Key="BtnBgPressedBrush"  Color="{StaticResource BtnBgPressed}" />
    <SolidColorBrush x:Key="BtnBgDisabledBrush" Color="{StaticResource BtnBgDisabled}" />

    <SolidColorBrush x:Key="BtnFgBrush" Color="WhiteSmoke" />
    <SolidColorBrush x:Key="BtnBorderBrush" Color="#40FFFFFF" />

    <!-- Implicit style: applies to ALL Buttons -->
    <Style TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{StaticResource BtnFgBrush}" />
        <Setter Property="Background" Value="{StaticResource BtnBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BtnBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource BtnBgHoverBrush}" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource BtnBgPressedBrush}" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource BtnBgDisabledBrush}" />
                            <Setter Property="Opacity" Value="0.6" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Optional variant: "Danger" button -->
    <Style x:Key="DangerButton"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="#8B0000" />
    </Style>
</ResourceDictionary>